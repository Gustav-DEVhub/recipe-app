{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "typeRoots": [
      "./server/node_modules/@types",
      "./client/node_modules/@types"
    ],
    "skipLibCheck": true
  },
  "include": ["api/**/*.ts"]
}
